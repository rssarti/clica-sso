{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env",
        "**/.env.local"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                "build/**",
                ".next/**"
            ],
            "cache": true
        },
        "lint": {
            "outputs": [],
            "cache": false
        },
        "test": {
            "outputs": [
                "coverage/**"
            ],
            "cache": true
        },
        "test:e2e": {
            "outputs": [
                "coverage/**"
            ],
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "start": {
            "cache": false,
            "persistent": true
        },
        "start:dev": {
            "cache": false,
            "persistent": true
        },
        "start:debug": {
            "cache": false,
            "persistent": true
        },
        "preview": {
            "cache": false,
            "persistent": true
        }
    }
}