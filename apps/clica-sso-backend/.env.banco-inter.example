# Banco Inter API Configuration
# Obtenha essas informações no portal do desenvolvedor do Banco Inter
# https://developers.inter.co/

# Client ID e Secret obtidos no portal do desenvolvedor
BANCO_INTER_CLIENT_ID=sd4fd78c1-5147-4a3f-b3b8-da8918aa83df
BANCO_INTER_CLIENT_SECRET=a7739aea-5965-418e-9c30-75142605e5db

# Caminhos para os certificados (formato .pem)
# Você deve baixar os certificados do portal do desenvolvedor
BANCO_INTER_CERT_PATH=./certs/banco-inter-cert.pem
BANCO_INTER_KEY_PATH=./certs/banco-inter-key.pem

# URL base da API (sandbox ou produção)
# Sandbox: https://cdpj-sandbox.partners.uatinter.co
# Produção: https://cdpj.partners.inter.co
BANCO_INTER_BASE_URL=https://cdpj-sandbox.partners.uatinter.co

# Escopos necessários para a API de cobrança
BANCO_INTER_SCOPE=cobranca-v3.read cobranca-v3.write
