{
  "name": "clica-sso-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.0.5",
  "engines": {
    "node": "22.x",
    "pnpm": "^9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-with-types": "tsc -b && vite build",
    "build:prod": "NODE_ENV=production vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "serve -s dist -l $PORT --no-clipboard --single --config serve.json",
    "docker:build": "docker build -t clica-sso-front .",
    "docker:run": "docker run -p 3000:80 clica-sso-front",
    "docker:dev": "docker build -t clica-sso-front . && docker run -p 3000:80 -e VITE_API_URL=http://localhost:3001 clica-sso-front",
    "preview:docker": "docker build -t clica-sso-front . && docker run -p 3000:80 clica-sso-front"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@types/js-cookie": "^3.0.6",
    "@types/qrcode": "^1.5.5",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.11.0",
    "js-cookie": "^3.0.5",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.0",
    "serve": "^14.2.5",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "picomatch": "^2.3.1",
    "postcss": "^8.5.6",
    "rollup": "^4.0.0",
    "tailwindcss": "3.4.10",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2"
  }
}
