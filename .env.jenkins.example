# ==========================================
# ENV FILE PARA JENKINS - CLICA SSO
# ==========================================
# 
# Este arquivo mostra o formato correto do ENV_FILE no Jenkins
# 
# ⚠️  NUNCA comita este arquivo com valores reais!
# 
# Para atualizar no Jenkins:
# 1. Acesse Jenkins > Manage Credentials > System > Global credentials
# 2. Clique em "Add Credentials"
# 3. Tipo: "Secret file"
# 4. File: (upload ou cole este arquivo com valores reais)
# 5. ID: clica-sso-env-file
# 6. Description: "Clica SSO Environment File"
#
# ==========================================

# ===== DATABASE (EXTERNO) =====
DATABASE_URL=postgresql://postgres:sua_senha@seu-host.com:5432/clica_sso
DB_USER=postgres
DB_PASSWORD=sua_senha_postgres

# ===== JWT =====
JWT_SECRET=sua-chave-jwt-super-secreta-aqui-mude-em-producao

# ===== RABBITMQ =====
RABBITMQ_URL=amqp://admin:admin123@seu-rabbitmq-host:5672/
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123

# ===== S3 / DIGITALOCEAN SPACES (se aplicável) =====
S3_ACCESS_KEY=sua-do-access-key
S3_SECRET_KEY=sua-do-secret-key
S3_ENDPOINT=https://sfo3.digitaloceanspaces.com
S3_REGION=us-east-1
S3_BUCKET=seu-bucket-name

# ===== FRONTEND BUILD ARGS =====
# Estas variáveis são usadas durante o build do Dockerfile
VITE_API_URL=https://api.clicatecnologia.com.br
VITE_SOCKET_IO=wss://ws.clicatecnologia.com.br
VITE_SOCKET_PATCH=/socket.io/

# ===== GENERAL =====
NODE_ENV=production
LOG_LEVEL=info

# ==========================================
# INSTRUÇÕES PARA CONFIGURAR NO JENKINS
# ==========================================
#
# 1. COPIAR ESTE ARQUIVO E PREENCHER COM VALORES REAIS
#
# 2. ENTRAR NO JENKINS
#    - URL: http://seu-jenkins.com
#    - Menu: Manage Jenkins > Manage Credentials
#
# 3. CRIAR NOVA CREDENTIAL DE ARQUIVO
#    - Clique: "System" > "Global credentials"
#    - Clique: "Add Credentials" (canto esquerdo)
#    - Form preenchido com:
#      * Kind: "Secret file"
#      * ID: clica-sso-env-file
#      * Description: "Clica SSO Environment File"
#      * File: (upload este arquivo com valores preenchidos)
#      * Create
#
# 4. CONFIGURAR CREDENCIAIS ADICIONAIS
#
#    a) DockerHub (Username + Password)
#       - Kind: "Username with password"
#       - Username: seu-usuario-dockerhub
#       - Password: seu-token-dockerhub
#       - ID: dockerhub-credentials
#
#    b) DockerHub Username (só o nome, sem senha)
#       - Kind: "Secret text"
#       - Secret: seu-usuario-dockerhub
#       - ID: dockerhub-username
#
#    c) K3s Token (do Service Account)
#       - Kind: "Secret text"
#       - Secret: (token do K3s - veja instruções abaixo)
#       - ID: clica-sso-k3s-token
#
# 5. OBTER TOKEN DO K3S
#    Execute no K3s:
#    ```
#    kubectl create token jenkins-deployer -n clica-sso
#    ```
#    Copie o token completo e cole no Jenkins
#
# 6. TESTE O PIPELINE
#    - Crie um novo Job no Jenkins
#    - Pipeline: Pipeline script from SCM
#    - SCM: Git
#    - Repository URL: https://seu-repo.git
#    - Branch: */main
#    - Script Path: Jenkinsfile
#    - Salve e teste
#
# ==========================================
# VERIFICAÇÃO DE SEGURANÇA
# ==========================================
# 
# ✓ As credenciais estão no Jenkins (não em Git)
# ✓ O arquivo .env-file é do tipo Secret no Jenkins
# ✓ Os valores sensíveis não são logados no pipeline
# ✓ O arquivo de configuração do K8s usa referências puras
#
# ==========================================
